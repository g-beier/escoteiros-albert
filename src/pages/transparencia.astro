  <WidgetWrapper>
    <iframe
      class="border-gray h-[50vh] min-h-60 w-full rounded-md border-4"
      src="https://docs.google.com/spreadsheets/d/e/2PACX-1vQaCuKIEqC0uPjxQFTmpWA6k0CT2qwuQesnGmcudaxE167Y5UyurJLMfaUGf6AfmE4TdbwNRP6Xksfh/pubhtml?gid=1711792376&single=true&widget=false&headers=false&chrome=false"
    ></iframe>
  </WidgetWrapper>

  <!-- <Steps2
    id="atas"
    tagline="Registros"
    title="Atas e relatórios de atividades"
    subtitle="Registros das principais decisões e das atividades realizadas pelo grupo."
    items={[
      {
        title: `Ata da Assembleia Geral Ordinária 2026`,
        description: 'Aprovação das contas, eleição de diretoria (quando aplicável) e deliberações gerais.',
        icon: 'tabler:notes',
      },
      {
        title: `Relatório de Atividades 2026`,
        description:
          'Resumo das atividades educativas realizadas em cada ramo: acampamentos, eventos, projetos comunitários.',
        icon: 'tabler:report',
      },
