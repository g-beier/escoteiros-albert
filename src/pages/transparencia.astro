---
import Layout from '@layouts/PageLayout.astro';
import HeroText from '@components/widgets/HeroText.astro';
import Stats from '@components/widgets/Stats.astro';
import Content from '@components/widgets/Content.astro';
import Steps2 from '@components/widgets/Steps2.astro';
import FAQs from '@components/widgets/FAQs.astro';
import CallToAction from '@components/widgets/CallToAction.astro';
import { getAsset } from '~/utils/permalinks';
import { Icon } from 'astro-icon/components';
import ItemList from '~/components/ui/ItemList.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

const metadata = {
  title: 'Transparência',
  description: 'Prestação de contas e documentos oficiais do Grupo Escoteiro Albert Schweitzer — GEAS 38/RS.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="GEAS 38/RS"
    title="Transparência"
    subtitle={`O Grupo Escoteiro Albert Schweitzer é uma associação sem fins lucrativos.<br/>
      Aqui você encontra nossas prestações de contas, documentos institucionais<br/>
      e informações sobre como o grupo é gerido.`}
  />

  <Stats
    tagline={`Exercício 2026`}
    title="O grupo em números"
    stats={[
      {
        amount: '41',
        title: 'Jovens',
        icon: 'tabler:users',
      },
      {
        amount: '19',
        title: 'Voluntários',
        icon: 'tabler:heart-handshake',
      },
    ]}
    footnote="Dados atualizados em 21.5.2026"
  />

  <Content id="documentos" tagline="Documentação" title="Documentos institucionais" isReversed>
    <Fragment slot="content">
      <p class="mb-6">
        Associação civil sem fins lucrativos, parceira da Comunidade Martin Luther e filiada à União dos Escoteiros do
        Brasil. Documentos disponíveis para consulta mediante solicitação à diretoria.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href={getAsset('documents/geas-estatuto.pdf')}
          download="geas-estatuto.pdf"
          class="border-primary bg-primary hover:bg-primary/90 inline-flex items-center gap-2 rounded-full border px-5 py-2.5 text-sm font-semibold text-white shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 17V3"></path><path d="m6 11 6 6 6-6"></path><path d="M19 21H5"></path></svg
          >
          Estatuto
        </a>
        <a
          href={getAsset('documents/geas05-regulamento.pdf')}
          download="geas-regulamento.pdf"
          class="border-primary text-primary hover:bg-primary/10 inline-flex items-center gap-2 rounded-full border px-5 py-2.5 text-sm font-semibold shadow-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 17V3"></path><path d="m6 11 6 6 6-6"></path><path d="M19 21H5"></path></svg
          >
          Regulamento
        </a>
      </div>
    </Fragment>

    <Fragment slot="image">
      <ItemList
        items={[
          // {
          //   title: 'Estatuto Social',
          //   description: 'Finalidade, estrutura e regras de funcionamento.',
          //   icon: 'tabler:file-certificate',
          // },
          {
            title: 'CNPJ <span class="font-mono font-normal">64.376.475/0001-60</span>',
            description: 'Cadastro Nacional da Pessoa Jurídica.',
            icon: 'tabler:building-bank',
          },
          // {
          //   title: 'Certificado de Funcionamento',
          //   description: 'Credenciamento junto à UEB e à Região RS.',
          //   icon: 'tabler:shield-check',
          // },
          // {
          //   title: 'Ata de Eleição da Diretoria',
          //   description: 'Última assembleia eleitoral, registrada em cartório.',
          //   icon: 'tabler:notes',
          // },
        ]}
      />
    </Fragment>
  </Content>

