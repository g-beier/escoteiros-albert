---
import { ANALYTICS } from 'astrowind:config';

const { id, partytown = true } = ANALYTICS?.vendors?.googleAnalytics ?? {};
const type = partytown ? 'text/partytown' : 'text/javascript';
const gaConfig = `window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${id}');`;
---

{
  id && (
    <>
      <script is:inline type={type} async src={`https://www.googletagmanager.com/gtag/js?id=${id}`} />
      <script is:inline type={type} set:html={gaConfig} />
    </>
  )
}
